/ {
    pwmleds {
        compatible = "pwm-leds";
        pwm_led_pa5: pwm_led_pa5 {
            pwms = <&pwm2 1 PWM_MSEC(20) PWM_POLARITY_NORMAL>;
            label = "PWM_LED";
        };
    };

    aliases {
        pwm-led0 = &pwm_led_pa5;
    };    
};

&timers2 {
    status = "okay";
    pwm2: pwm {
        status = "okay";
        pinctrl-0 = <&tim2_ch1_pa5>;
        pinctrl-names = "default";
    };
};